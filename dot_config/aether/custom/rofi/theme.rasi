* {
    font: "JetBrainsMono Nerd Font 14";
    background-color: transparent;
}

configuration {
    modi:        "drun,run,window";
    show-icons:  false;
    drun-display-format: "{name}";
}

window {
    location:         center;
    width:            315px;
    height:           300px;
    border:           0px;
    border-color:     {foreground};
    border-radius:    15px;
    background-color: {background};
}

mainbox {
    padding: 5px 10px;
}

prompt {
    enabled: false;
}

inputbar {
    children:         [ entry ];
    padding:          0 0 8px 0;
    background-color: transparent;
}

entry {
    placeholder:       "";
    placeholder-color: {foreground};
    cursor:            text;
    cursor-color:      {accent};
    text-color:        {foreground};
    background-color:  transparent;
}

listview {
    lines:            10;
    spacing:          2px;
    cycle:            true;
    dynamic:          true;
    layout:           vertical;
    fixed-height:     0;
    background-color: transparent;
}

element {
    padding:          6px 10px;
    text-color:       {foreground};
    background-color: transparent;
}

element selected {
    background-color: transparent;
    text-color:       {accent};
}

element-text selected {
    background-color: transparent;
    text-color:       {accent};
  }

element-text {
    text-color:       {foreground};
    background-color: transparent;
}

element-icon {
    size:             0;
    background-color: transparent;
}

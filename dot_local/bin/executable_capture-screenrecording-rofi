#!/bin/bash

if pgrep -f "^gpu-screen-recorder" >/dev/null; then
  capture-screenrecording --stop-recording
  exit 0
fi

entries=(
  "ó°‘‹  Desktop audio only"
  "ď„°  Desktop + microphone"
  "ď‰Ť  Region + desktop audio"
  "ď†’  Fullscreen + desktop audio"
  "ď…Š  Fullscreen + desktop + mic"
  "ď‘„  Webcam + desktop audio"
)

selected=$(printf '%s\n' "${entries[@]}" | rofi -dmenu -p "Screen recording")

case "$selected" in
  "ó°‘‹  Desktop audio only")       capture-screenrecording --fullscreen --with-desktop-audio ;;
  "ď„°  Desktop + microphone")      capture-screenrecording --fullscreen --with-desktop-audio --with-microphone-audio ;;
  "ď‰Ť  Region + desktop audio")    capture-screenrecording --with-desktop-audio ;;
  "ď†’  Fullscreen + desktop audio")  capture-screenrecording --fullscreen --with-desktop-audio ;;
  "ď…Š  Fullscreen + desktop + mic")  capture-screenrecording --fullscreen --with-desktop-audio --with-microphone-audio ;;
  "ď‘„  Webcam + desktop audio")    capture-screenrecording --with-desktop-audio --with-webcam ;;
esac

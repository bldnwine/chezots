#!/bin/bash

if pgrep -f "^gpu-screen-recorder" >/dev/null; then
  capture-screenrecording --stop-recording
  exit 0
fi

entries=(
  "Desktop audio only"
  "Desktop + microphone"
  "Fullscreen + desktop audio"
  "Fullscreen + desktop + mic"
  "Webcam + desktop audio"
)

selected=$(printf '%s\n' "${entries[@]}" | rofi -dmenu -p "Screen recording" -theme-str 'window {width: 20%;}')

case "$selected" in
"Desktop audio only") capture-screenrecording --with-desktop-audio ;;
"Desktop + microphone") capture-screenrecording --with-desktop-audio --with-microphone-audio ;;
"Fullscreen + desktop audio") capture-screenrecording --fullscreen --with-desktop-audio ;;
"Fullscreen + desktop + mic") capture-screenrecording --fullscreen --with-desktop-audio --with-microphone-audio ;;
"Webcam + desktop audio") capture-screenrecording --with-desktop-audio --with-webcam ;;
esac

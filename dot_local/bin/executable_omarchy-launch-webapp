#!/bin/bash

# Get default browser
browser=$(xdg-settings get default-web-browser)

# Categorize: chromium-based gets --app mode, firefox-based gets normal window
case $browser in
    google-chrome*|brave-browser*|microsoft-edge*|opera*|vivaldi*|helium*|chromium*)
        APP_MODE="--app" ;;
    zen*|firefox*)
        APP_MODE="" ;;
    *)
        browser="chromium.desktop"
        APP_MODE="--app" ;;
esac

# Extract Exec path from desktop file
EXEC_PATH=$(sed -n 's/^Exec=\([^ ]*\).*/\1/p' \
    ~/.local/share/applications/$browser \
    /usr/share/applications/$browser \
    ~/.nix-profile/share/applications/$browser \
    2>/dev/null | head -1)

# Fallback: try command name from desktop file
if [ -z "$EXEC_PATH" ]; then
    cmd=$(echo "$browser" | sed 's/.desktop$//')
    if command -v "$cmd" &> /dev/null; then
        EXEC_PATH="$cmd"
    else
        notify-send "Web App Error" "Could not find browser executable: $browser"
        exit 1
    fi
fi

# Launch
if [ -n "$APP_MODE" ]; then
    exec "$EXEC_PATH" "$APP_MODE=$1" "${@:2}"
else
    exec "$EXEC_PATH" --blank-window "$1" "${@:2}"
fi

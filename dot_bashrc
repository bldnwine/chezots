##FUNCTIONS##
twitch() {
    if [ -z "$1" ] || [ -z "$2" ]; then
        echo "Usage: twitch <channel> <quality> (e.g., twitch chess24 480p or twitch chess24 best)"
        return 1
    fi
    streamlink --player mpv --player-args "-" "https://www.twitch.tv/$1" "$2"
}
export PATH="$HOME/.local/bin:$PATH"

cd() {
    builtin cd "$@" && [ -n "$1" ] && ls -AF || true
}
amd() {
    DRI_PRIME=1 "$@"
}
yta() {
    mkdir -p ~/Music
    yt-dlp -x --audio-format m4a --embed-metadata --embed-thumbnail --convert-thumbnails jpg --compat-options embed-thumbnail-atomicparsley -o "~/Music/%(title)s.%(ext)s" "$1"
}

ytv() {
    mkdir -p ~/Videos
    yt-dlp -f "bv*[height<=1080]+ba/b[height<=1080]" -o "~/Videos/%(title)s.%(ext)s" "$1"
}

un() {
    gocryptfs "$1" "akeru"
}

proton() {
    if [ "$1" = "down" ]; then
        # Find and bring down any active proton interface
        local active_interfaces=$(wg show interfaces)
        for iface in $active_interfaces; do
            if [[ "$iface" == proton* ]]; then
                sudo wg-quick down "$iface"
            fi
        done
    elif [[ "$1" =~ ^[0-9]+$ ]]; then
        # Automatically tear down existing proton connections to avoid routing conflicts
        local active_interfaces=$(wg show interfaces)
        for iface in $active_interfaces; do
            if [[ "$iface" == proton* ]]; then
                sudo wg-quick down "$iface"
            fi
        done
        sudo wg-quick up "proton$1"
    else
        echo "Usage: proton [number] (e.g., proton 1) or proton down"
        return 1
    fi
}

mus() {
    if [ "${1:-}" = "ls" ]; then
        yazi "${HOME}/Music"
        return 0
    fi
    local music_dir="${HOME}/Music/${1:-}"

    if [ ! -d "$music_dir" ]; then
        echo "Error: Directory $music_dir does not exist." >&2
        return 1
    fi
    mpv --shuffle --no-video --term-osd-bar --load-scripts=no --script=/etc/mpv/scripts/mpris.so "$music_dir"
}
rmpcx() {
    (
        systemctl --user start mpd.service 
        trap 'systemctl --user stop mpd.service' EXIT
        rmpc
    )
